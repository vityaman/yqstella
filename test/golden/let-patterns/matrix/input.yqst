language core;

extend with
    #let-bindings,
    #let-patterns,
    #structural-patterns,
    #unit-type,
    #tuples,
    #records,
    #lists;

fn main(n : Nat) -> [Nat] {
  return
    let a = succ(n) in
    let {b, c} = {succ(a), succ(succ(a))} in
    let { a = d, b = e } = { a = succ(b), b = succ(c) } in
    let unit = unit in
        [a, b, c, d, e]
}
