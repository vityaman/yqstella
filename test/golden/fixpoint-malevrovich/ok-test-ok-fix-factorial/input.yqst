language core;
extend with
  #fixpoint-combinator,
  #natural-literals,
  #predecessor
;

fn multiply(n : Nat) -> fn(Nat) -> Nat {
  return fn(m : Nat) {
    return Nat::rec(m, 0, fn(prev : Nat) {
      return fn(acc : Nat) {
        return Nat::rec(n, acc, fn(p : Nat) {
          return fn(a : Nat) {
            return succ(a)
          }
        })
      }
    })
  }
}

fn main(n : Nat) -> Nat {
  return fix(fn(self : fn(Nat) -> Nat) {
    return fn(x : Nat) {
      return if Nat::iszero(x) then 1 else multiply(x)(self(Nat::pred(x)))
    }
  })(n)
}
