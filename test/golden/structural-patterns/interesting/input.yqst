language core;

extend with
  #structural-patterns,
  #natural-literals,
  #arithmetic-operators,
  #type-aliases,
  #tuples,
  #records
;

type InputSum = { Nat, Nat }
type OutputSum = Nat

fn TestSum(n : InputSum) -> Nat {
  return match (n) { { n, m } => n + m }
}

type Input = {
  sum : InputSum
}

type Output = {
  sum : OutputSum
}

fn main(input : Input) -> Output {
  return {
    sum = TestSum(input.sum)
  }
}
