language core;

extend with
  #structural-patterns,
  #natural-literals,
  #arithmetic-operators,
  #type-aliases,
  #unit-type,
  #tuples,
  #records
;

type  InputTupleSum = { Nat, Nat }
type OutputTupleSum = Nat
fn     TestTupleSum(n : InputTupleSum) -> OutputTupleSum {
  return match (n) { { n, m } => n + m }
}

type  InputRecordSum = { a : Nat, b :Nat }
type OutputRecordSum = Nat
fn     TestRecordSum(n : InputRecordSum) -> OutputRecordSum {
  return match (n) { { a = a, b = b } => a + b }
}

type  InputBool = Bool
type OutputBool = Nat
fn     TestBool(n : InputBool) -> OutputBool {
  return match (n) {
      false => 0
    | true => 1
  }
}

type  InputUnit = Unit
type OutputUnit = Unit
fn     TestUnit(n : InputUnit) -> OutputUnit {
  return match (n) {
    unit => unit
  }
}

type  InputSucc = Nat
type OutputSucc = Nat
fn     TestSucc(n : InputSucc) -> OutputSucc {
  return match (n) {
      succ(succ(n)) => 2 + n
    | succ(n)       => 1 + 0
    | 0             => 0 + 0
  }
}

type Input = {
  ITupleSum : InputTupleSum,
  IRecordSum : InputRecordSum,
  IBool : InputBool,
  IUnit : InputUnit,
  ISucc : InputSucc
}

type Output = {
  OTupleSum : OutputTupleSum,
  ORecordSum : OutputRecordSum,
  OBool : OutputBool,
  OUnit : OutputUnit,
  OSucc : OutputSucc
}

fn main(input : Input) -> Output {
  return {
    OTupleSum = TestTupleSum(input.ITupleSum),
    ORecordSum = TestRecordSum(input.IRecordSum),
    OBool = TestBool(input.IBool),
    OUnit = TestUnit(input.IUnit),
    OSucc = TestSucc(input.ISucc)
  }
}
