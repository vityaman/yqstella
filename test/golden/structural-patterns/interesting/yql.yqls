    (return (Unwrap (Coalesce yqstellamatchbr0)))))))
  (let InputSucc (Void))
  (let OutputSucc (Void))
  (let TestSucc (lambda '(n) (block '(
    (let yqstellamatchexpr n)
    (let yqstellamatchbr0
      (Apply
        (lambda '(yqstellamatcharg) (block '(
          (let n
            (Apply
              mapcoerce
              (Apply
                mapcoerce
                yqstellamatcharg
                (lambda '(x) (OptionalIf (!= x (Uint64 '0)) (-MayWarn x (Uint64 '1)))))
              (lambda '(x) (OptionalIf (!= x (Uint64 '0)) (-MayWarn x (Uint64 '1))))))
          (let yqstellamatchcond (And (Exists n) (Bool 'true)))
