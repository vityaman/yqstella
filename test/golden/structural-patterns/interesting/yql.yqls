          (let yqstellamatchfalse:29:7 (OptionalIf (Not yqstellamatcharg) (Bool 'false)))
          (let yqstellamatchcond (And (Exists yqstellamatchfalse:29:7) (Bool 'true)))
          (let yqstellamatchfalse:29:7 (Unwrap yqstellamatchfalse:29:7))
          (return (If yqstellamatchcond (Just (Uint64 '0)) (Nothing (OptionalType (DataType 'Uint64))))))))
        yqstellamatchexpr))
    (let yqstellamatchbr1
      (Apply
        (lambda '(yqstellamatcharg) (block '(
          (let yqstellamatchtrue:30:7 (OptionalIf yqstellamatcharg (Bool 'true)))
          (let yqstellamatchcond (And (Exists yqstellamatchtrue:30:7) (Bool 'true)))
          (let yqstellamatchtrue:30:7 (Unwrap yqstellamatchtrue:30:7))
          (return (If yqstellamatchcond (Just (Uint64 '1)) (Nothing (OptionalType (DataType 'Uint64))))))))
        yqstellamatchexpr))
    (return (Unwrap (Coalesce yqstellamatchbr0 yqstellamatchbr1)))))))
  (let InputUnit (Void))
  (let OutputUnit (Void))
  (let TestUnit (lambda '(n) (block '(
    (let yqstellamatchexpr n)
    (let yqstellamatchbr0
      (Apply
