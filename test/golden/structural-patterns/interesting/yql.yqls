  (let Input (Void))
  (let Output (Void))
  (let main (lambda '(input)
    (AsStruct
      '('OTupleSum (Apply TestTupleSum (Member input 'ITupleSum)))
      '('ORecordSum (Apply TestRecordSum (Member input 'IRecordSum)))
      '('OBool (Apply TestBool (Member input 'IBool)))
      '('OUnit (Apply TestUnit (Member input 'IUnit)))
      '('OSucc (Apply TestSucc (Member input 'ISucc))))))
  (declare
    __input__
    (StructType
      '('ITupleSum (TupleType (DataType 'Uint64) (DataType 'Uint64)))
      '('IRecordSum (StructType '('a (DataType 'Uint64)) '('b (DataType 'Uint64))))
