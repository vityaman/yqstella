          (let yqstellamatchunit:38:5 yqstellamatcharg)
          (let yqstellamatchcond (And (Exists yqstellamatchunit:38:5) (Bool 'true)))
          (let yqstellamatchunit:38:5 (Unwrap yqstellamatchunit:38:5))
          (return (If yqstellamatchcond (Just (Void)) (Nothing (OptionalType (VoidType))))))))
