(
  (let print (lambda '(world rows) (block '(
    (let sink (DataSink 'result))
    (let options '('('type) '('autoref) '('unordered)))
    (let world (ResFill! world sink (Key) rows options 'pure))
    (return (Commit! world sink))))))
  (let InputSum (Void))
  (let OutputSum (Void))
  (let TestSum (lambda '(n) (block '(
    (let yqstellamatchexpr n)
    (let yqstellamatchbr0
      (Apply
        (lambda '(yqstellamatcharg) (block '(
          (let m (Nth yqstellamatcharg '1))
          (let n (Nth yqstellamatcharg '0))
          (let yqstellamatchcond (And (Exists m) (And (Exists n) (Bool 'true))))
          (let m (Unwrap m))
          (let n (Unwrap n))
          (return (If yqstellamatchcond (Just (+MayWarn n m)) (Nothing (OptionalType (DataType 'Uint64))))))))
        yqstellamatchexpr))
    (return (Unwrap (Coalesce yqstellamatchbr0)))))))
  (let Input (Void))
  (let Output (Void))
  (let main (lambda '(input) (AsStruct '('sum (Apply TestSum (Member input 'sum))))))
  (declare __input__ (StructType '('sum (TupleType (DataType 'Uint64) (DataType 'Uint64)))))
  (let result (Apply main __input__))
  (let world (Apply print world (AsList (AsStruct '('result result)))))
  (return world)
)