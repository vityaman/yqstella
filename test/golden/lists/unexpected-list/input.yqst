language core;

extend with #lists;

fn literal0(x : Nat) -> Nat {
  return []
}

fn literal1(x : Nat) -> Nat {
  return [x]
}

fn literal2(x : Nat) -> Nat {
  return [x, x]
}

fn cons1literal0(x : Nat) -> Nat {
  return cons(x, [])
}

fn cons2literal0(x : Nat) -> Nat {
  return cons(x, cons(x, []))
}

fn cons1literal1(x : Nat) -> Nat {
  return cons(x, [x])
}

fn main(x : Nat) -> Nat {
  return x
}
