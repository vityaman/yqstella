(
  (let print (lambda '(world rows) (block '(
    (let sink (DataSink 'result))
    (let options '('('type) '('autoref) '('unordered)))
    (let world (ResFill! world sink (Key) rows options 'pure))
    (return (Commit! world sink))))))
  (let nonempty (lambda '(list) (If (Not (HasItems list)) (Bool 'false) (Bool 'true))))
  (let first_or_default (lambda '(list default)
    (If (Apply nonempty list) (Unwrap (ToOptional list)) default)))
  (let main (lambda '(default)
    (Apply first_or_default (ToList (Nothing (OptionalType (DataType 'Uint64)))) default)))
  (declare __default__ (DataType 'Uint64))
  (let result (Apply main __default__))
  (let world (Apply print world (AsList (AsStruct '('result result)))))
  (return world)
)