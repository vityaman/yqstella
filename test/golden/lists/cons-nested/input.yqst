language core;

extend with
  #arithmetic-operators,
  #lists,
  #natural-literals;

// Fizruk: well-typed. yqstella: ERROR_UNEXPECTED_LIST on nested cons
// (see also list-forest: literals used instead in llm/).

fn g(n : Nat) -> [Nat] {
  return cons(0, cons(1, cons(n, [])))
}

fn main(n : Nat) -> Nat {
  return List::head(g(n))
}
