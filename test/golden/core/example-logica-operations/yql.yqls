(
  (let print (lambda '(world rows) (block '(
    (let sink (DataSink 'result))
    (let options '('('type) '('autoref) '('unordered)))
    (let world (ResFill! world sink (Key) rows options 'dq))
    (return (Commit! world sink))
  ))))
  (let Bool::not (lambda '(b)
    (If b (Bool 'false) (Bool 'true))))
  (let Bool::or (lambda '(a)
    (lambda '(b)
      (If a (Bool 'true) b))))
  (let Bool::and (lambda '(a)
    (lambda '(b)
      (If a b (Bool 'false)))))
  (let Bool::xor (lambda '(a)
    (lambda '(b)
      (Apply (Apply Bool::or (Apply (Apply Bool::and a) (Apply Bool::not b))) (Apply (Apply Bool::and (Apply Bool::not a)) b)))))
  (let main (lambda '(n)
    (Apply (Apply Bool::xor (Apply (Apply Bool::and n) (Apply Bool::not n))) (Apply (Apply Bool::or (Apply Bool::not n)) n))))
  (declare __n__ (DataType 'Bool))
  (let result (Apply main __n__))
  (let world (Apply print world (AsList (AsStruct '('result result)))))
  (return world)
)
