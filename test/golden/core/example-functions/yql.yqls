(
  (let print (lambda '(world rows) (block '(
    (let sink (DataSink 'result))
    (let options '('('type) '('autoref) '('unordered)))
    (let world (ResFill! world sink (Key) rows options 'dq))
    (return (Commit! world sink))))))
  (let plus2 (lambda '(n) (+ (+ n (Uint64 '1)) (Uint64 '1))))
  (let Bool::not (lambda '(b) (If b (Bool 'false) (Bool 'true))))
  (let twice (lambda '(f) (lambda '(x) (Apply f (Apply f x)))))
  (let main (lambda '(b) (Apply (Apply twice Bool::not) b)))
  (declare __b__ (DataType 'Bool))
  (let result (Apply main __b__))
  (let world (Apply print world (AsList (AsStruct '('result result)))))
  (return world)
)