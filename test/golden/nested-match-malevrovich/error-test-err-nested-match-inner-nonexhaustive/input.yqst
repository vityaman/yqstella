// Nested match: ERROR_NONEXHAUSTIVE_MATCH_PATTERNS
// inner match on variant is missing a label
language core;
extend with #sum-types, #variants;

fn main(x : <| left : Nat + Bool, right : Nat |>) -> Nat {
  return match x {
      <| left = inner |> => match inner {
          inl(n) => n
          // missing: inr case
      }
    | <| right = n |> => n
  }
}
