// Nested match: variant inside variant
language core;
extend with #variants;

fn main(x : <| outer : <| a : Nat, b : Bool |>, other : Nat |>) -> Nat {
  return match x {
      <| outer = inner |> => match inner {
          <| a = n |> => n
        | <| b = f |> => if f then 1 else 0
      }
    | <| other = n |> => succ(n)
  }
}
