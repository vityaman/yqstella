// Nested match: variant inside sum type
language core;
extend with #sum-types, #variants, #natural-literals;

fn main(x : <| a : Nat, b : Bool |> + Nat) -> Nat {
  return match x {
      inl(v) => match v {
          <| a = n |> => n
        | <| b = f |> => if f then 1 else 0
      }
    | inr(n) => succ(n)
  }
}
