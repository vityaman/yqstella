    (return (Unwrap (Coalesce yqstellamatchbr0 yqstellamatchbr1)))))))
  (let xor_bb (lambda '(a b) (block '(
    (let yqstellamatchexpr a)
    (let yqstellamatchbr0
      (Apply
        (lambda '(yqstellamatcharg) (block '(
          (let t (Guess yqstellamatcharg 'inl))
          (let yqstellamatchcond (And (Exists t) (Bool 'true)))
          (let t (Unwrap t))
