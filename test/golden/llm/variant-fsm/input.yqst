language core;

extend with
  #arithmetic-operators,
  #comparison-operators,
  #let-bindings,
  #multiparameter-functions,
  #nullary-functions,
  #natural-literals,
  #sum-types,
  #type-ascriptions,
  #unit-type;

// Four-state automaton as nested (Unit+Unit)+(Unit+Unit). Events are Bools from the input.

fn s0() -> (Unit + Unit) + (Unit + Unit) {
  return inl(inl(unit)) as ((Unit + Unit) + (Unit + Unit))
}

fn s1() -> (Unit + Unit) + (Unit + Unit) {
  return inl(inr(unit)) as ((Unit + Unit) + (Unit + Unit))
}

fn s2() -> (Unit + Unit) + (Unit + Unit) {
  return inr(inl(unit)) as ((Unit + Unit) + (Unit + Unit))
}

fn s3() -> (Unit + Unit) + (Unit + Unit) {
  return inr(inr(unit)) as ((Unit + Unit) + (Unit + Unit))
}

fn is_s0(s : (Unit + Unit) + (Unit + Unit)) -> Bool {
  return match (s) {
      inl(ul) => match (ul) {
        inl(t) => true
        | inr(t) => false
      }
    | inr(ur) => false
  }
}

fn is_s3(s : (Unit + Unit) + (Unit + Unit)) -> Bool {
  return match (s) {
      inl(ul) => false
    | inr(ur) => match (ur) {
        inl(t) => false
        | inr(t) => true
      }
  }
}

fn next_on_true(s : (Unit + Unit) + (Unit + Unit)) -> (Unit + Unit) + (Unit + Unit) {
  return match (s) {
      inl(ul) => match (ul) {
        inl(t) => s1()
        | inr(t) => s2()
      }
    | inr(ur) => match (ur) {
        inl(t) => s3()
        | inr(t) => s0()
      }
  }
}

fn next_on_false(s : (Unit + Unit) + (Unit + Unit)) -> (Unit + Unit) + (Unit + Unit) {
  return match (s) {
      inl(ul) => match (ul) {
        inl(t) => s0()
        | inr(t) => s0()
      }
    | inr(ur) => match (ur) {
        inl(t) => s0()
        | inr(t) => s1()
      }
  }
}

fn step(s : (Unit + Unit) + (Unit + Unit), e : Bool) -> (Unit + Unit) + (Unit + Unit) {
  return if e then next_on_true(s) else next_on_false(s)
}

fn run_three(
  s0st : (Unit + Unit) + (Unit + Unit),
  e0 : Bool,
  e1 : Bool,
  e2 : Bool
) -> (Unit + Unit) + (Unit + Unit) {
  return let t1 = step(s0st, e0) in
         let t2 = step(t1, e1) in
         step(t2, e2)
}

fn as_reward(s : (Unit + Unit) + (Unit + Unit)) -> Nat {
  return if is_s0(s) then
    1
  else if is_s3(s) then
    3
  else
    2
}

fn main(n : Nat) -> Nat {
  return let e0 = n < 1 in
         let e1 = n == 1 in
         let e2 = n > 2 in
         let t = run_three(s0(), e0, e1, e2) in
         as_reward(t)
}
